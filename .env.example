# =============================================================================
# auto-job-application — environment configuration
# Copy this file to .env and fill in the values you need.
# =============================================================================

# =============================================================================
# Browser Automation
# =============================================================================

# Chrome DevTools Protocol endpoint — start Chrome with:
#   bun browser   (runs: google-chrome-stable --remote-debugging-port=9222 ...)
# Then paste the ws:// URL printed by `bun cdp`
CDP_ENDPOINT=your-cdp-endpoint-here

# =============================================================================
# Model Configuration
# =============================================================================
# Every model value uses the format:  <provider>/<model-path>
#
# Supported providers and their prefixes:
#   openrouter    — https://openrouter.ai          (cloud, 200+ models)
#   openai        — https://platform.openai.com    (cloud)
#   lmstudio      — http://localhost:1234           (local, LMStudio app)
#   github-models — https://models.github.ai       (cloud, free tier)
#   ollama        — http://localhost:11434          (local, Ollama app)
#   z-ai          — https://open.bigmodel.cn       (cloud, Zhipu AI / GLM)
#
# Examples:
#   openrouter/qwen/qwen3-30b-a3b-instruct-2507
#   openai/gpt-4o
#   lmstudio/qwen/qwen3-30b-a3b-2507
#   github-models/openai/gpt-4o
#   ollama/llama3.2
#   z-ai/glm-4.7-flash
# =============================================================================

# Fallback used when an agent-specific or service-specific var below is not set.
DEFAULT_MODEL=openrouter/qwen/qwen3-30b-a3b-instruct-2507

# --- Per-agent model overrides -----------------------------------------------
# Remove the override to fall back to DEFAULT_MODEL.

# Conversational profile-building agent (tool-heavy, benefits from fast models)
PROFILE_AGENT_MODEL=z-ai/glm-4.7-flash

# Resume generation agent (writing-focused, benefits from instruction-following)
RESUME_AGENT_MODEL=z-ai/glm-4.7-flash

# Job application browser-automation agent (multi-step, needs reliable tool use)
JOB_APPLICATION_AGENT_MODEL=openrouter/qwen/qwen3.5-flash-02-23

# Job board orchestrator + scraping agents (shared default for all board agents)
JOB_BOARD_AGENT_MODEL=openrouter/qwen/qwen3-30b-a3b-instruct-2507

# Per-board overrides — each falls back to JOB_BOARD_AGENT_MODEL if unset
# JOB_BOARD_LINKEDIN_MODEL=openrouter/qwen/qwen3-30b-a3b-instruct-2507
# JOB_BOARD_GREENHOUSE_MODEL=openrouter/qwen/qwen3-30b-a3b-instruct-2507
# JOB_BOARD_GENERIC_MODEL=openrouter/qwen/qwen3-30b-a3b-instruct-2507

# --- Service-level model overrides -------------------------------------------
# These control models used by backend services (not agents).
# Falls back to DEFAULT_MODEL if unset.

# Model used by ResumeGenerationService and TypstResumeService for LLM calls
# (structured JSON generation, resume text production).
# RESUME_SERVICE_MODEL=openrouter/qwen/qwen3-30b-a3b-instruct-2507

# Embedding model used by DocumentService for RAG vector embeddings.
# Must be an embedding-capable model (not a chat/completion model).
# Format is the same <provider>/<model-path> pattern.
# Examples:
#   openrouter/openai/text-embedding-3-small
#   openai/text-embedding-3-small
#   ollama/nomic-embed-text
#   lmstudio/text-embedding-nomic-embed-text-v1.5
EMBEDDING_MODEL=openrouter/openai/text-embedding-3-small

# =============================================================================
# Provider API Keys & Base URLs
# =============================================================================
# Only configure the sections for providers you actually use.
# Base URL overrides are optional — only needed for proxies or non-default ports.
#
# IMPORTANT: You only need API keys for providers that appear in your model
# strings above. For example, if every model is set to lmstudio/... you do NOT
# need OPENROUTER_API_KEY at all.
# =============================================================================

# --- OpenRouter --------------------------------------------------------------
# Required when any model string starts with "openrouter/" or when z-ai/ models
# are used without a ZAI_API_KEY (falls back to OpenRouter automatically).
# Get your key: https://openrouter.ai/keys
# OPENROUTER_API_KEY=your-openrouter-api-key-here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- OpenAI ------------------------------------------------------------------
# Required when any model string starts with "openai/".
# Get your key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- LMStudio ----------------------------------------------------------------
# No API key required — LMStudio runs fully locally.
# Override LMSTUDIO_BASE_URL if your server runs on a different host or port.
# Download LMStudio: https://lmstudio.ai
# LMSTUDIO_API_KEY=lmstudio
# LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1

# --- GitHub Models -----------------------------------------------------------
# Required when any model string starts with "github-models/".
# Create a personal access token: https://github.com/settings/tokens
# (no special scopes needed for public model access)
# GITHUB_TOKEN=github_pat_...
# GITHUB_MODELS_BASE_URL=https://models.github.ai/inference

# --- Ollama ------------------------------------------------------------------
# No API key required — Ollama runs fully locally.
# Override OLLAMA_BASE_URL if Ollama runs on a different host or port.
# Download Ollama: https://ollama.com
# OLLAMA_BASE_URL=http://localhost:11434/api

# --- Z.AI / Zhipu AI (GLM models) -------------------------------------------
# Optional. When ZAI_API_KEY is set, z-ai/ models are called directly via the
# Z.AI API. When unset, they are routed through OpenRouter instead (requires
# OPENROUTER_API_KEY above).
# Get your key: https://open.bigmodel.cn/usercenter/apikeys
# ZAI_API_KEY=your-zai-api-key
# ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
